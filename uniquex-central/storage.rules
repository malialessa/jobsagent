rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Editais PDF (LiciAI e AnalisadorEdital)
    match /editais/{userId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Termos de Referência PDF (AnalisadorTR)
    match /termos-referencia/{userId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Arquivos gerais de usuários
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
