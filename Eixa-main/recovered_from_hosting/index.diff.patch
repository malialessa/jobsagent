+        function buildMoodChartSvg(points, options = {}) {
+            if (!Array.isArray(points) || points.length === 0) {
+                return '<div style="color:var(--text-secondary); font-size:13px;">Sem dados suficientes.</div>';
+            }
+
+            const width = options.width || 640;
+            const height = options.height || 220;
+            const padding = options.padding ?? 24;
+            const minScore = 1;
+            const maxScore = 10;
+            const step = points.length > 1 ? (width - padding * 2) / (points.length - 1) : 0;
+
+            const coords = points.map((point, index) => {
+                const x = padding + step * index;
+                if (typeof point.score === 'number') {
+                    const ratio = (point.score - minScore) / (maxScore - minScore);
+                    const y = height - padding - ratio * (height - padding * 2);
+                    return { x, y, point };
+                }
+                return { x, y: null, point };
+            });
+
+            const definedCoords = coords.filter(c => c.y !== null);
+            if (!definedCoords.length) {
+                return '<div style="color:var(--text-secondary); font-size:13px;">Sem dados suficientes.</div>';
+            }
+
+            let pathD = '';
+            coords.forEach((coord, idx) => {
+                if (coord.y === null) return;
+                pathD += `${pathD ? ' L' : 'M'} ${coord.x.toFixed(2)} ${coord.y.toFixed(2)}`;
+            });
+
+            const firstCoord = definedCoords[0];
+            const lastCoord = definedCoords[definedCoords.length - 1];
+            const areaPath = `${pathD} L ${lastCoord.x.toFixed(2)} ${height - padding} L ${firstCoord.x.toFixed(2)} ${height - padding} Z`;
+
+            const dots = definedCoords.map(coord => {
+                const note = coord.point.notes && coord.point.notes.length ? `\n${coord.point.notes[0]}` : '';
+                return `<circle cx="${coord.x.toFixed(2)}" cy="${coord.y.toFixed(2)}" r="${options.dotRadius || 4}" fill="var(--accent-primary)">
+                    <title>${coord.point.weekday} (${coord.point.date}): ${coord.point.score}${note}</title>
+                </circle>`;
+            }).join('');
+
+            const baselineY = height - padding - ((5 - minScore) / (maxScore - minScore)) * (height - padding * 2);
+
+            return `
+                <svg viewBox="0 0 ${width} ${height}" class="mood-chart-svg" preserveAspectRatio="none">
+                    <defs>
+                        <linearGradient id="moodGradient" x1="0" x2="0" y1="0" y2="1">
+                            <stop offset="0%" stop-color="rgba(124,58,237,0.4)" />
+                            <stop offset="100%" stop-color="rgba(59,130,246,0.1)" />
+                        </linearGradient>
+                    </defs>
+                    <line x1="${padding}" x2="${width - padding}" y1="${baselineY.toFixed(2)}" y2="${baselineY.toFixed(2)}" stroke="rgba(255,255,255,0.08)" stroke-dasharray="4 4" />
+                    <path d="${areaPath}" fill="url(#moodGradient)" opacity="0.25"></path>
+                    <path d="${pathD}" fill="none" stroke="var(--accent-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
+                    ${dots}
+                </svg>
+            `;
+        }
+
+        function buildMoodSparkline(points) {
+            return buildMoodChartSvg(points ? points.slice(-7) : [], { width: 260, height: 90, padding: 12, dotRadius: 3 });
+        }
